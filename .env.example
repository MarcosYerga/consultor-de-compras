# API (apps/api)
PORT=3001
HOST=0.0.0.0

# Respuestas demo en POST /v1/compare?demo=1 (además de DEMO_MODE)
DEMO_MODE=false

# Mercadona: API JSON pública tienda.mercadona.es (sin login de lectura).
# mock = conector simulado (por defecto, ideal para CI/desarrollo sin red).
# live = categorías reales + filtrado por texto (ver README).
MERCADONA_MODE=mock
MERCADONA_WAREHOUSE=vlc1

# Lidl ES: API JSON de búsqueda (/q/api/search)
LIDL_MODE=mock

# Dia: página /search con JSON SSR (vike_pageContext)
DIA_MODE=mock

# Ahorramas: Search-ShowAjax (Salesforce Commerce Cloud)
AHORRAMAS_MODE=mock

# Eroski: HTML de búsqueda supermercado.eroski.es (data-metrics en enlaces de producto).
EROSKI_MODE=mock

# Carrefour: HTML Next.js (__NEXT_DATA__). Muchas IPs de servidor reciben 403 (Cloudflare).
CARREFOUR_MODE=mock

# El Corte Inglés: HTML supermercado. Akamai puede devolver 403.
EL_CORTE_INGLES_MODE=mock

# Cache de respuestas live (fallback real: dato stale) para despliegue en VPS.
# Ruta por defecto: apps/api/.cache/live-search-cache.json
# LIVE_CACHE_FILE=apps/api/.cache/live-search-cache.json
# Tiempo máximo (minutos) para reutilizar cache live cuando el retailer falla.
LIVE_CACHE_MAX_AGE_MINUTES=360

# User-Agent opcional para todas las peticiones de conectores
# CONNECTOR_USER_AGENT="ConsultorDeCompras/1.0 (+https://tu-dominio)"
